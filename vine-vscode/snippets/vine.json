{
  "Mutable Variable": {
    "prefix": "lowkey",
    "body": ["lowkey ${1:name} ${2|int,float,string,bool|} = ${3:value}"],
    "description": "Declare a mutable variable (lowkey = var)"
  },

  "Immutable Constant (noCap)": {
    "prefix": "noCap",
    "body": ["noCap ${1:name} ${2|int,float,string,bool|} = ${3:value}"],
    "description": "Declare an immutable constant"
  },

  "Immutable Constant (lockIn)": {
    "prefix": "lockIn",
    "body": ["lockIn ${1:name} ${2|int,float,string,bool|} = ${3:value}"],
    "description": "Declare an immutable constant (lockIn = noCap)"
  },

  "Forge Function": {
    "prefix": "forge",
    "body": [
      "forge ${1:name}(${2:params}) ${3:void} {",
      "\t${0}",
      "}"
    ],
    "description": "Define a function (forge = func)"
  },

  "Forge Main": {
    "prefix": "main",
    "body": [
      "forge main() void {",
      "\t${0}",
      "}"
    ],
    "description": "Main entry point"
  },

  "Spill (Print)": {
    "prefix": "spill",
    "body": ["spill(${1:value})"],
    "description": "Print to stdout (spill = print)"
  },

  "Perchance (If)": {
    "prefix": "perchance",
    "body": [
      "perchance (${1:condition}) {",
      "\t${0}",
      "}"
    ],
    "description": "If statement (perchance = if)"
  },

  "Perchance / Otherwise (If-Else)": {
    "prefix": "perchance-otherwise",
    "body": [
      "perchance (${1:condition}) {",
      "\t${2}",
      "} otherwise {",
      "\t${0}",
      "}"
    ],
    "description": "If-else statement"
  },

  "Perchance / Otherwise Chain (Else-If)": {
    "prefix": "perchance-chain",
    "body": [
      "perchance (${1:condition1}) {",
      "\t${2}",
      "} otherwise perchance (${3:condition2}) {",
      "\t${4}",
      "} otherwise {",
      "\t${0}",
      "}"
    ],
    "description": "If / else-if / else chain"
  },

  "LetHimCook (While Loop)": {
    "prefix": "letHimCook",
    "body": [
      "letHimCook (${1:condition}) {",
      "\t${0}",
      "}"
    ],
    "description": "While loop (letHimCook = while)"
  },

  "SpinTheBlock (For Loop)": {
    "prefix": "spinTheBlock",
    "body": [
      "spinTheBlock (lowkey ${1:i} int = ${2:0}; ${1} < ${3:10}; ${1} = ${1} + 1) {",
      "\t${0}",
      "}"
    ],
    "description": "For loop (spinTheBlock = for)"
  },

  "CheckTheFit (Switch)": {
    "prefix": "checkTheFit",
    "body": [
      "checkTheFit (${1:value}) {",
      "\tstyle ${2:case1}: {",
      "\t\t${3}",
      "\t}",
      "\tstyle ${4:case2}: {",
      "\t\t${5}",
      "\t}",
      "\tnoFilter: {",
      "\t\t${0}",
      "\t}",
      "}"
    ],
    "description": "Switch/match statement (checkTheFit = switch)"
  },

  "Attempt / Catch (Try-Catch)": {
    "prefix": "attempt",
    "body": [
      "attempt {",
      "\t${1}",
      "} catch ${2:err} {",
      "\tspill(\"caught: \" + ${2})",
      "\t${0}",
      "}"
    ],
    "description": "Try-catch block (attempt/catch)"
  },

  "ThrowHands (Throw Error)": {
    "prefix": "throwHands",
    "body": ["throwHands(\"${1:error message}\")"],
    "description": "Throw an error (throwHands = throw)"
  },

  "itIsWhatItIs (Return)": {
    "prefix": "itIsWhatItIs",
    "body": ["itIsWhatItIs ${0}"],
    "description": "Return statement"
  },

  "Full Vine Starter Program": {
    "prefix": "vine-starter",
    "body": [
      "// ${1:My Vine Program}",
      "",
      "forge main() void {",
      "\tspill(\"${2:no cap this slaps}\")",
      "\t${0}",
      "}"
    ],
    "description": "A minimal Vine starter program"
  },

  "Recursive Forge": {
    "prefix": "forge-recursive",
    "body": [
      "forge ${1:factorial}(${2:n} ${3:int}) ${4:int} {",
      "\tperchance (${2} <= 1) {",
      "\t\titIsWhatItIs 1",
      "\t}",
      "\titIsWhatItIs ${2} * ${1}(${2} - 1)",
      "}"
    ],
    "description": "Recursive function template"
  }
}
