{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Vine",
  "scopeName": "source.vine",
  "fileTypes": ["vine"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#null" },
    { "include": "#forge-declaration" },
    { "include": "#declaration-keywords" },
    { "include": "#control-flow" },
    { "include": "#loop-keywords" },
    { "include": "#error-handling" },
    { "include": "#io-keywords" },
    { "include": "#operators" },
    { "include": "#types" },
    { "include": "#function-call" },
    { "include": "#identifiers" }
  ],
  "repository": {

    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.vine",
          "match": "//.*$"
        }
      ]
    },

    "strings": {
      "name": "string.quoted.double.vine",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.vine",
          "match": "\\\\[\"\\\\ntr]"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.vine",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.vine",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },

    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.vine",
          "match": "\\bbet\\b"
        },
        {
          "name": "constant.language.boolean.false.vine",
          "match": "\\bnah\\b"
        }
      ]
    },

    "null": {
      "name": "constant.language.null.vine",
      "match": "\\bghostd\\b"
    },

    "forge-declaration": {
      "comment": "forge functionName(params) returnType { }",
      "patterns": [
        {
          "name": "meta.function.vine",
          "match": "\\b(forge)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "keyword.declaration.function.vine" },
            "2": { "name": "entity.name.function.vine" }
          }
        }
      ]
    },

    "declaration-keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.variable.mutable.vine",
          "match": "\\blowkey\\b"
        },
        {
          "name": "keyword.declaration.variable.immutable.vine",
          "match": "\\b(noCap|lockIn)\\b"
        },
        {
          "name": "keyword.control.return.vine",
          "match": "\\bitIsWhatItIs\\b"
        }
      ]
    },

    "control-flow": {
      "patterns": [
        {
          "name": "keyword.control.conditional.vine",
          "match": "\\bperchance\\b"
        },
        {
          "name": "keyword.control.conditional.else.vine",
          "match": "\\botherwise\\b"
        },
        {
          "name": "keyword.control.switch.vine",
          "match": "\\bcheckTheFit\\b"
        },
        {
          "name": "keyword.control.case.vine",
          "match": "\\bstyle\\b"
        },
        {
          "name": "keyword.control.default.vine",
          "match": "\\bnoFilter\\b"
        }
      ]
    },

    "loop-keywords": {
      "patterns": [
        {
          "name": "keyword.control.loop.while.vine",
          "match": "\\bletHimCook\\b"
        },
        {
          "name": "keyword.control.loop.for.vine",
          "match": "\\bspinTheBlock\\b"
        },
        {
          "name": "keyword.control.loop.break.vine",
          "match": "\\bghost\\b"
        },
        {
          "name": "keyword.control.loop.continue.vine",
          "match": "\\bkeepItMoving\\b"
        }
      ]
    },

    "error-handling": {
      "patterns": [
        {
          "name": "keyword.control.trycatch.try.vine",
          "match": "\\battempt\\b"
        },
        {
          "name": "keyword.control.trycatch.catch.vine",
          "match": "\\bcatch\\b"
        },
        {
          "name": "keyword.control.throw.vine",
          "match": "\\bthrowHands\\b"
        }
      ]
    },

    "io-keywords": {
      "patterns": [
        {
          "comment": "spill() is the print function — treat it like a keyword call",
          "name": "meta.function-call.builtin.vine",
          "match": "\\b(spill)\\s*(?=\\()",
          "captures": {
            "1": { "name": "support.function.builtin.vine" }
          }
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.equality.vine",
          "match": "\\bisGiving\\b"
        },
        {
          "name": "keyword.operator.comparison.vine",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.vine",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.arithmetic.vine",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.assignment.vine",
          "match": "(?<![=!<>])=(?!=)"
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "name": "storage.type.vine",
          "match": "\\b(int|float|string|bool|void)\\b"
        }
      ]
    },

    "function-call": {
      "comment": "Highlights any user-defined function call: name(...)",
      "name": "meta.function-call.vine",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.vine" }
      }
    },

    "identifiers": {
      "name": "variable.other.vine",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}
